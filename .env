# ─── Alarm App — Environment Variables ────────────────────────
# Copy this file to .env and adjust as needed.
#
# No secrets are required — the app runs entirely client-side
# using localStorage for persistence.
#
# VITE_* variables are bundled by Vite and available in browser code.
# ──────────────────────────────────────────────────────────────

# (Optional) Override the default dev server port
# VITE_PORT=8080